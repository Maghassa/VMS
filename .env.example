# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://vms_user:change_me_strong_password@postgres:5432/vms

# JWT
JWT_SECRET=change_me_64_char_random_secret_here_use_openssl_rand_hex_32
JWT_REFRESH_SECRET=change_me_64_char_random_refresh_secret_use_openssl_rand_hex_32

# CRM Staging
STAGING_DB_URL=postgresql://vms_user:change_me_strong_password@postgres:5432/vms
STAGING_API_TOKEN=change_me_staging_api_token

# Domain (used by Nginx and frontend)
DOMAIN=vms.meydan.ae

# Thresholds
DISK_WARNING_PCT=70
DISK_CRITICAL_PCT=85
AUTO_DISMISS_HOURS=24

# Storage
STORAGE_PATH=/storage
